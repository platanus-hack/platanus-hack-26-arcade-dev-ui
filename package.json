{
  "name": "@platanus-hack/arcade-dev-ui-26",
  "version": "0.1.0",
  "description": "Dev UI package for Platanus Hack 26 Arcade Challenge",
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    },
    "./check-restrictions": {
      "import": "./dist/check-restrictions.js",
      "types": "./dist/check-restrictions.d.ts"
    }
  },
  "bin": {
    "arcade-check-restrictions": "./dist/cli.js"
  },
  "files": [
    "dist",
    "dashboard.html"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "platanus-hack",
    "arcade",
    "vite-plugin",
    "dev-ui"
  ],
  "author": "platanus-hack",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/platanus-hack/platanus-hack-26-arcade-dev-ui.git"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "dependencies": {
    "@swc/core": "^1.13.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "vite": "^7.1.12"
  }
}
